generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id             String      @id @default(uuid()) @db.Uuid
  nome           String
  email          String      @unique
  dataNascimento DateTime
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  alugueis       Aluguel[]
  avaliacoes     Avaliacao[]
  endereco       Endereco?   @relation("UsuarioEndereco")

  @@map("usuarios")
}

model Proprietario {
  id        String    @id @default(uuid()) @db.Uuid
  nome      String
  email     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  alugueis  Aluguel[]
  endereco  Endereco? @relation("ProprietarioEndereco")

  @@map("proprietarios")
}

model Aluguel {
  id             String       @id @default(uuid()) @db.Uuid
  titulo         String
  descricao      String?
  preco          Decimal      @db.Decimal(10, 2)
  dataInicio     DateTime
  dataFim        DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  proprietarioId String       @map("proprietario_id") @db.Uuid
  usuarioId      String       @map("usuario_id") @db.Uuid
  proprietario   Proprietario @relation(fields: [proprietarioId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  avaliacoes     Avaliacao[]
  pagamento      Pagamento?   @relation("AluguelPagamento")

  @@unique([usuarioId, dataInicio])
  @@map("alugueis")
}

model Avaliacao {
  id         String   @id @default(uuid()) @db.Uuid
  nota       Int
  comentario String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  aluguelId  String   @map("aluguel_id") @db.Uuid
  usuarioId  String   @map("usuario_id") @db.Uuid
  aluguel    Aluguel  @relation(fields: [aluguelId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([aluguelId, usuarioId])
  @@map("avaliacoes")
}

model Pagamento {
  id            String          @id @default(uuid()) @db.Uuid
  valor         Decimal         @db.Decimal(10, 2)
  metodo        MetodoPagamento
  status        StatusPagamento @default(PENDENTE)
  dataPagamento DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  aluguelId     String          @unique @map("aluguel_id") @db.Uuid
  aluguel       Aluguel         @relation("AluguelPagamento", fields: [aluguelId], references: [id])

  @@map("pagamentos")
}

model Endereco {
  id             String        @id @default(uuid()) @db.Uuid
  rua            String
  numero         String?
  complemento    String?
  cidade         String
  estado         String
  pais           String
  cep            String
  latitude       Decimal?      @db.Decimal(10, 8)
  longitude      Decimal?      @db.Decimal(11, 8)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  usuarioId      String?       @unique @map("usuario_id") @db.Uuid
  proprietarioId String?       @unique @map("proprietario_id") @db.Uuid
  proprietario   Proprietario? @relation("ProprietarioEndereco", fields: [proprietarioId], references: [id])
  usuario        Usuario?      @relation("UsuarioEndereco", fields: [usuarioId], references: [id])

  @@map("enderecos")
}

enum MetodoPagamento {
  PIX
  CARTAO
  BOLETO
}

enum StatusPagamento {
  PENDENTE
  PAGO
  CANCELADO
}

model Imovel {
  id             String        @id @default(uuid()) @db.Uuid
  titulo         String
  descricao      String?
  tipoImovel      TipoImovel
  endereco       Endereco      @relation(fields: [enderecoId], references: [id])
  enderecoId     String        @map("endereco_id") @db.Uuid
  proprietario   Proprietario  @relation(fields: [proprietarioId], references: [id])
  proprietarioId String        @map("proprietario_id") @db.Uuid
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("imoveis")
}

enum TipoImovel {
  CASA
  APARTAMENTO
  QUARTO
  VILA
}